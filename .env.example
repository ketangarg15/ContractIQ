# ── FastAPI Backend Environment Variables ──────────────────────────────────────

# Groq API Key (required for LLM services)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Supabase Database URL (optional, falls back to local SQLite if unset)
DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Supabase Storage Configuration (optional, falls back to local disk if unset)
SUPABASE_URL=https://your-project-ref.supabase.co
# WARNING: This service role key is a highly sensitive credential with bypass-RLS capabilities.
# It must NEVER be shared, exposed to the frontend, or committed to version control.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_STORAGE_BUCKET=contract-texts
